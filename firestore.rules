rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sync/{syncKey}/invoices
    // Document ID: invoiceId
    // Fields:
    //   - id: string (required) - Unique ID for the invoice.
    //   - syncKey: string (required) - The secret key for syncing across devices.
    //   - customerName: string (required) - Name of the customer.
    //   - invoiceDate: string (required) - Date the invoice was created (ISO format).
    //   - items: list (required) - List of product items.
    //   - advances: list (optional) - List of advance payments.
    //   - total: number (required) - Total amount due.
    //   - updatedAt: number (required) - Timestamp of last update.
    //
    // ===============================================================

    function isValidInvoice(data, syncKey) {
      return data.keys().hasAll(['id', 'syncKey', 'customerName', 'invoiceDate', 'items', 'total', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.syncKey is string && data.syncKey == syncKey &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.invoiceDate is string && data.invoiceDate.size() <= 20 &&
             data.items is list && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sync/{syncKey}/invoices/{invoiceId} {
      // Security by obscurity: only those who know the syncKey can access
      allow read: if syncKey.size() >= 8;
      allow create, update: if syncKey.size() >= 8 && isValidInvoice(request.resource.data, syncKey);
      allow delete: if syncKey.size() >= 8;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
