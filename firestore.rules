rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: invoices
    // Document ID: {invoiceId}
    // Fields:
    //   - id: string (required) - Invoice ID
    //   - userId: string (required) - User ID of the creator
    //   - customerName: string (required) - Name of the customer
    //   - invoiceDate: string (required) - Date of the invoice
    //   - items: string (required) - JSON stringified items
    //   - total: number (required) - Total amount
    //   - updatedAt: number (required) - Last updated timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidInvoice(data) {
      return hasRequiredFields(['id', 'userId', 'customerName', 'invoiceDate', 'items', 'total', 'updatedAt']) &&
             data.id is string &&
             data.userId is string &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.invoiceDate is string && data.invoiceDate.size() <= 50 &&
             data.items is string && data.items.size() <= 1000000 &&
             data.total is number && data.total >= 0 &&
             data.updatedAt is number;
    }

    match /invoices/{invoiceId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidInvoice(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isDocOwner() && isValidInvoice(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
