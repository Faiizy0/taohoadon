{
  "entities": {
    "Invoice": {
      "title": "Invoice",
      "description": "A saved invoice for a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the invoice." },
        "syncKey": { "type": "string", "description": "The secret key for syncing across devices." },
        "customerName": { "type": "string", "description": "Name of the customer." },
        "invoiceDate": { "type": "string", "description": "Date the invoice was created (ISO format)." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "orderDate": { "type": "string" }
            }
          }
        },
        "advances": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "date": { "type": "string" },
              "amount": { "type": "number" }
            }
          }
        },
        "total": { "type": "number", "description": "Total amount due." },
        "updatedAt": { "type": "number", "description": "Timestamp of last update." }
      },
      "required": ["id", "syncKey", "customerName", "invoiceDate", "items", "total", "updatedAt"]
    }
  },
  "firestore": {
    "/sync/{syncKey}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User-owned invoices synced via secret key."
    }
  }
}
