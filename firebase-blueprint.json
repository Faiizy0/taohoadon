{
  "entities": {
    "Invoice": {
      "title": "Invoice",
      "description": "A customer invoice containing product items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "invoiceDate": { "type": "string" },
        "items": {
          "type": "string",
          "description": "JSON stringified array of items"
        },
        "total": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "customerName", "invoiceDate", "items", "total", "updatedAt"]
    }
  },
  "firestore": {
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Stores user invoices"
    }
  }
}
